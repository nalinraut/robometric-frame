# Auto detect text files and perform LF normalization
* text=auto

# Python files
*.py text eol=lf

# Documentation
*.md text eol=lf
*.rst text eol=lf

# Config files
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf

# Scripts
*.sh text eol=lf
*.bash text eol=lf

# Jupyter notebooks
*.ipynb text eol=lf
